# 複製這個檔案成 .env,填入你自己的值。.env 不會進版控。

# Spotify(Day 2 開始用)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Spotify 2025 起不接受 http://localhost,本機用 loopback IP 127.0.0.1
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# Gemini(Day 4 開始用)
# 申請:https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 可選,預設 gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash

# Last.fm(Day 3:補 Spotify 拿不到的 artist 曲風)
# 申請:https://www.last.fm/api/account/create
LASTFM_API_KEY=

# 資料庫
DATABASE_URL=sqlite:///./musicapp.db
